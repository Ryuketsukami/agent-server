# ─────────────────────────────────────────────────────────────────────────────
# .env.vastai.example — Vast.ai GPU instance deployment
# Model server: Ollama on RTX 3090 (24 GB VRAM)
# Agent server: langgraph dev via startup.sh (runs on the instance)
#
# ⚠ You do NOT copy this file to the Vast.ai instance manually.
#   startup.sh generates .env automatically from the instance's environment.
#   This file exists purely as documentation of what gets written.
# ─────────────────────────────────────────────────────────────────────────────

# ── Set these in Vast.ai dashboard → instance → Environment ──────────────────
# (These are the only env vars you configure in the Vast.ai UI)

MODEL_NAME=qwen3:8b

# ─────────────────────────────────────────────────────────────────────────────
# The remaining variables are written by startup.sh — do not set them in
# the Vast.ai dashboard (startup.sh hardcodes the correct values for Ollama).
# ─────────────────────────────────────────────────────────────────────────────

MODEL_BASE_URL=http://localhost:11434/v1
# MODEL_API_KEY=ollama           ← written by startup.sh, not configurable
# COST_PER_INPUT_TOKEN=0.0       ← written by startup.sh
# COST_PER_OUTPUT_TOKEN=0.0      ← written by startup.sh
# OPENROUTER_REFERER=            ← written by startup.sh (blank for Vast.ai)
# OPENROUTER_TITLE=              ← written by startup.sh (blank for Vast.ai)
# MAX_CONCURRENT_RUNS=3          ← written by startup.sh

# ── What to set where (outside this file) ────────────────────────────────────
#
# GITHUB ACTIONS SECRETS (repo → Settings → Secrets and variables → Actions):
#   VAST_API_KEY     = your Vast.ai API key
#                      Get it at: vastai.com → Account → API key
#   VAST_INSTANCE_ID = the numeric ID of your Vast.ai instance
#                      Run `vastai show instances` after creating the instance
#                      Or find it in the Vast.ai dashboard URL
#
# VERCEL (portfolio-frontend repo):
#   NUXT_VASTAI_AGENT_URL = https://<instance-ip>:<mapped-8123-port>
#                           Find the mapped port in the Vast.ai instance panel
#
# VAST.AI INSTANCE CONFIG (dashboard → instance settings):
#   Docker image  : pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime
#   On-start cmd  : bash -c "$(curl -fsSL https://raw.githubusercontent.com/Ryuketsukami/agent-server/main/startup.sh)"
#   Exposed port  : 8123
#   Disk          : 40 GB minimum

# ── Automated schedule ────────────────────────────────────────────────────────
# .github/workflows/vast-start.yml  — starts the instance at 06:30 IL, Sun–Thu
# .github/workflows/vast-stop.yml   — stops the instance at 17:00 IL, Sun–Thu
# Requires VAST_API_KEY + VAST_INSTANCE_ID in GitHub Actions secrets.
