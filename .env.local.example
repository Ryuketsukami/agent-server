# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example — Local desktop deployment
# Model server: Ollama running on your own machine (RTX 4080)
# Agent server: langgraph dev --tunnel (Cloudflare generates a public URL)
#
# Usage:
#   cp .env.local.example .env
#   # No edits needed — defaults work out of the box for local Ollama
# ─────────────────────────────────────────────────────────────────────────────

# ── All values — uncomment everything, no changes needed ─────────────────────

MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen3:8b
MODEL_API_KEY=ollama

COST_PER_INPUT_TOKEN=0.0
COST_PER_OUTPUT_TOKEN=0.0

OPENROUTER_REFERER=
OPENROUTER_TITLE=

MAX_CONCURRENT_RUNS=3

# ── What to set where (outside this file) ────────────────────────────────────
#
# VERCEL (portfolio-frontend repo):
#   NUXT_LOCAL_AGENT_URL = the Cloudflare Tunnel URL printed by langgraph dev --tunnel
#                          e.g. https://abc123.trycloudflare.com
#                          ⚠ This URL changes every time you restart langgraph dev.
#                          For a stable URL, run cloudflared as a system service.
#
# GITHUB ACTIONS SECRETS (this repo):
#   VAST_API_KEY     — needed for the automated Vast.ai start/stop workflows
#   VAST_INSTANCE_ID — needed for the automated Vast.ai start/stop workflows
#   (These are unrelated to local deployment but live in the same repo)

# ── How to start ─────────────────────────────────────────────────────────────
#
#   OLLAMA_NUM_PARALLEL=3 ollama serve          # terminal 1 — keep open
#   ollama pull qwen3:8b                        # one-time, ~5 GB
#   cp .env.local.example .env
#   langgraph dev --port 8123 --tunnel --max-concurrent-runs 3
