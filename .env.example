# ─────────────────────────────────────────────────────────────────────────────
# agent-server — environment variables
# Copy this file to .env and fill in values for your target deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment A: Local (Ollama on desktop) ───────────────────────────────────
# MODEL_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=qwen3:8b
# MODEL_API_KEY=ollama             ← any non-empty string; Ollama ignores it
# COST_PER_INPUT_TOKEN=0.0
# COST_PER_OUTPUT_TOKEN=0.0

# ── Deployment B: Vast.ai (Ollama on GPU instance) ────────────────────────────
# These are set as environment variables in the Vast.ai instance dashboard,
# not in this file.  startup.sh writes its own .env on the instance.
# MODEL_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=qwen3:8b
# MODEL_API_KEY=ollama
# COST_PER_INPUT_TOKEN=0.0
# COST_PER_OUTPUT_TOKEN=0.0

# ── Deployment C: Railway (OpenRouter API) ────────────────────────────────────
# MODEL_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=qwen/qwen3-8b
# MODEL_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx   ← your OpenRouter secret key
# COST_PER_INPUT_TOKEN=0.00000005               # $0.05  / M tokens
# COST_PER_OUTPUT_TOKEN=0.0000004               # $0.40  / M tokens
# OPENROUTER_REFERER=https://your-portfolio.vercel.app
# OPENROUTER_TITLE=Portfolio Infrastructure Demo

# ─────────────────────────────────────────────────────────────────────────────
# Active values (edit these for your current deployment)
# ─────────────────────────────────────────────────────────────────────────────

MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen3:8b
MODEL_API_KEY=ollama

# USD cost per token — leave at 0.0 for Ollama deployments
COST_PER_INPUT_TOKEN=0.0
COST_PER_OUTPUT_TOKEN=0.0

# OpenRouter attribution headers (only used when MODEL_BASE_URL is openrouter.ai)
# OpenRouter uses these to identify your app in their dashboard and enforce
# per-app rate limits.  Safe to leave blank for local/Vast.ai deployments.
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# Rate limiting — max concurrent requests this server will accept.
# Matches OLLAMA_NUM_PARALLEL (3) so requests don't queue behind Ollama.
# LangGraph dev server: set via --max-concurrent-runs flag in startup commands.
MAX_CONCURRENT_RUNS=3

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Actions secrets (NOT set here — go to repo Settings → Secrets)
# ─────────────────────────────────────────────────────────────────────────────
# VAST_API_KEY        Your Vast.ai API key (vastai.com → Account → API key)
# VAST_INSTANCE_ID    Numeric ID of your Vast.ai instance
#                     Run `vastai show instances` after creating the instance
#
# Both are consumed by .github/workflows/vast-start.yml and vast-stop.yml.
# They never appear in .env — only in GitHub Actions.
