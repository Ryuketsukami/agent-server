# ─────────────────────────────────────────────────────────────────────────────
# agent-server — environment variables
# Copy this file to .env and fill in the values for your deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model endpoint ────────────────────────────────────────────────────────────
# OpenAI-compatible base URL for the model API.
#
# Local (Ollama on desktop):
#   MODEL_BASE_URL=http://localhost:11434/v1
#
# Vast.ai (Ollama on instance):
#   MODEL_BASE_URL=http://localhost:11434/v1
#
# Railway / OpenRouter:
#   MODEL_BASE_URL=https://openrouter.ai/api/v1
MODEL_BASE_URL=http://localhost:11434/v1

# Model identifier passed to the API.
#   Ollama:      qwen3:8b
#   OpenRouter:  qwen/qwen3-8b
MODEL_NAME=qwen3:8b

# API key.
#   Ollama self-hosted:  ollama  (any non-empty string works)
#   OpenRouter:          sk-or-...
MODEL_API_KEY=ollama

# ── Cost tracking (optional) ──────────────────────────────────────────────────
# USD per token.  Leave at 0.0 for self-hosted (local / Vast.ai) deployments.
# OpenRouter pricing (as of 2026-04): $0.05/M input, $0.40/M output.
COST_PER_INPUT_TOKEN=0.0
COST_PER_OUTPUT_TOKEN=0.0

# ── LangGraph Server ──────────────────────────────────────────────────────────
# Set by langgraph CLI — do not change unless you know what you're doing.
# LANGGRAPH_API_KEY is required in production (langgraph up).
# LANGGRAPH_API_KEY=your-langgraph-cloud-key
